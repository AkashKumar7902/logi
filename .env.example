LOGI_ENVIRONMENT=development
LOGI_SERVER_ADDRESS=:8080
LOGI_MONGO_URI=mongodb://localhost:27017/logi
LOGI_JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
LOGI_JWT_EXPIRATION_HOURS=72
LOGI_MESSAGING_TYPE=websocket
LOGI_NATS_URL=nats://localhost:4222
LOGI_DISTANCE_CALCULATOR_TYPE=haversine
LOGI_GOOGLE_MAPS_API_KEY=
LOGI_ALLOWED_ORIGINS=http://localhost:3000
LOGI_ENABLE_TEST_ROUTES=false
LOGI_DB_OPERATION_TIMEOUT_SECONDS=5
LOGI_HTTP_READ_TIMEOUT_SECONDS=15
LOGI_HTTP_WRITE_TIMEOUT_SECONDS=30
LOGI_HTTP_IDLE_TIMEOUT_SECONDS=60
LOGI_SHUTDOWN_TIMEOUT_SECONDS=15
